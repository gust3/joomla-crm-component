<?xml version="1.0" encoding="utf-8"?>
<extension type="component" version="4.0" method="upgrade">
    <name>com_crmstages</name>
    <creationDate>2026-02-24</creationDate>
    <copyright>2026 gust33</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <author>gust</author>
    <authorEmail>CWtorin@gmail.com</authorEmail>
    <authorUrl>http://</authorUrl>
    <version>CVS: 1.0.0</version>
    <description></description>
    <namespace path="src">Gust\Component\Crmstages</namespace>
    
    
    
    <install> <!-- Runs on install -->
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <update> <!-- Runs on update -->
        <schemas>
            <schemapath type="mysql">sql/updates</schemapath>
        </schemas>
    </update>
    <uninstall> <!-- Runs on uninstall -->
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    

    <files folder="site">
        <folder>src</folder>
        <folder>forms</folder>
        <folder>tmpl</folder>
    </files>
    <media destination="com_crmstages" folder="media">
        <folder>css</folder>
        <folder>js</folder>
        <filename>joomla.asset.json</filename>
    </media>
    <languages folder="site/languages">
        
			<language tag="ru-RU">ru-RU/com_crmstages.ini</language>
    </languages>
    <administration>
        <menu>COM_CRMSTAGES</menu>
        <submenu>
            
			<menu link="option=com_crmstages&amp;view=companies" view="companies" alt="Crmstages/Companies">COM_CRMSTAGES_TITLE_COMPANIES</menu>

			<menu link="option=com_crmstages&amp;view=companies" view="companies" alt="Crmstages/Companies">COM_CRMSTAGES_TITLE_COMPANIES</menu>

        </submenu>
        <files folder="administrator">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>forms</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <folder>services</folder>
            <folder>presets</folder>
            <folder>sql</folder>
        </files>
        <languages folder="administrator/languages">
            
			<language tag="ru-RU">ru-RU/com_crmstages.ini</language>
			<language tag="ru-RU">ru-RU/com_crmstages.sys.ini</language>
        </languages>
    </administration>
    <config>
        <fields name="params">
            <fieldset name="component">
                <field name="save_history" default="0" />
            </fieldset>
        </fields>
    </config>
    <plugins>
    </plugins>
</extension>

